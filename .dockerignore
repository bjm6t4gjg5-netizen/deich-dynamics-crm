# Only files that would bloat the build context.
# IMPORTANT: client/dist is intentionally NOT listed — although it's gitignored
# locally, if it ever exists on the build host we want it included rather than
# silently filtered out (Docker COPY would otherwise miss it).

node_modules
**/node_modules
.git
.github
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.lock
.env
.env.local
.env.*.local
.DS_Store
server/uploads/*
!server/uploads/.gitkeep
