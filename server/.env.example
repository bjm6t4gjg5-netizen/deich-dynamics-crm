# ─── Deich Dynamics CRM — Server Environment ───────────────────────────────
# Copy this file to `.env` and fill in real values for local development.
# Never commit the resulting `.env` file.

# Required
PORT=3001
NODE_ENV=development

# JWT signing secret — MUST be at least 32 random characters in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-32-plus-random-chars-for-local-development-only

# CORS — comma-separated list of allowed origins (no trailing slashes)
CLIENT_URL=http://localhost:5173

# Optional — used for the "from" address when no Steuerberater mailer is configured
MAIL_FROM_DEFAULT=noreply@deich-dynamics.com
MAIL_FROM_NAME_DEFAULT=Deich Dynamics CRM

# Optional — set in production to throttle aggressive clients
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_MAX=300

# Optional — seed admin overrides (only respected during db:init)
SEED_ADMIN_EMAIL=admin@deich-dynamics.com
SEED_ADMIN_PASSWORD=Admin2025!
