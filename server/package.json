{
  "name": "deich-dynamics-crm-server",
  "version": "1.0.0",
  "private": true,
  "description": "Deich Dynamics CRM — API server (Node/Express + SQLite).",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "db:init": "node db/init.js",
    "db:reset": "rm -f deich.db kontor.db *.db-journal *.db-wal *.db-shm *.db.lock && node db/init.js",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "node-sqlite3-wasm": "^0.8.30",
    "nodemailer": "^6.9.13",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0"
  }
}
